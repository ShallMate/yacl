# Ignore Bazel output directories (can be huge)
bazel-*

# Only include the upsi example and the core workspace files needed to build it
examples/*
!examples/upsi
!examples/upsi/**
!examples/psu
!examples/psu/**

# Dependencies are resolved by Bazel; do not send stale host-local artifacts.
third_party/local_apsi_fixed

# Ignore other potential junk
.git
.gitignore
.vscode
*.md
*.txt
!bazel/default_targets.txt
